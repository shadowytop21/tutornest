{
  "name": "docent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3000": "next dev -p 3000",
    "dev:clean": "node -e \"const fs=require('fs');for(const p of ['.next','node_modules/.cache']){if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});}console.log('Cleaned .next and node_modules/.cache');\"",
    "dev:fresh": "npm run dev:clean && npm run dev:3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "critters": "^0.0.23",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
